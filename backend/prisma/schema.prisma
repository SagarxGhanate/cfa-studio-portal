generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id            String    @id @default(uuid())
  name          String
  phone         String
  age           Int
  location      String
  society       String?
  avatar        String?   @db.Text
  joiningDate   DateTime
  isActive      Boolean   @default(true)
  classType     ClassType
  category      Category
  guardianName  String?
  guardianPhone String?
  adminId       String?
  admin         Admin?    @relation(fields: [adminId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum ClassType {
  PERSONAL
  GROUP
}

enum Category {
  KIDS
  TODDLERS
  ADULTS
}

enum Role {
  OWNER
  MANAGER
  VIEWER
}

model Admin {
  id               String     @id @default(uuid())
  email            String     @unique
  password         String
  initialPassword  String?
  name             String?
  avatar           String?
  role             Role       @default(OWNER)
  teamId           String?    // Links MANAGER/VIEWER to OWNER's id
  team             Admin?     @relation("TeamMembers", fields: [teamId], references: [id])
  teamMembers      Admin[]    @relation("TeamMembers")
  resetOtp         String?
  resetOtpExpiry   DateTime?
  members          Member[]
  auditLogs        AuditLog[]
  createdAt        DateTime   @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // CREATE, UPDATE, DELETE, BULK_IMPORT, WIPE_ALL, STATUS_TOGGLE, LOGIN
  entity    String   // MEMBER, ADMIN, TEAM
  entityId  String?  // Target entity ID (null for bulk ops)
  details   String?  @db.Text // JSON string with change context
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}
